# Pflicht: zufälliger Secret-Key (z. B. openssl rand -base64 32)
AUTH_SECRET=bitte-ein-zufaelliger-langer-string

# Option A: mehrere User (user:pass,user2:pass2)
AUTH_USERS=admin:dein-passwort,mitarbeiter:zweites-passwort

# Option B: ein einzelner User (Alternative zu AUTH_USERS)
# AUTH_USERNAME=admin
# AUTH_PASSWORD=dein-passwort
