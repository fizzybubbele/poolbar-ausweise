# Lokal ohne Login (nur Entwicklung):
AUTH_DISABLED=true

# Online / Produktion — Login aktivieren:
# AUTH_DISABLED=false
# AUTH_SECRET=bitte-ein-zufaelliger-langer-string
# AUTH_USERS=admin:dein-passwort,mitarbeiter:zweites-passwort

# Option B: ein einzelner User (Alternative zu AUTH_USERS)
# AUTH_USERNAME=admin
# AUTH_PASSWORD=dein-passwort

# Impressum / Datenschutz (optional — Standard: Poolbar Kultur gGmbH)
# LEGAL_ENTITY_NAME=Poolbar Kultur gGmbH
# LEGAL_ADDRESS=Austraße 35, 6800 Feldkirch, Österreich
# LEGAL_EMAIL=ahoi@poolbar.at
# LEGAL_WEBSITE=www.poolbar.at
# LEGAL_REPRESENTATIVE=Herwig Bauer
# LEGAL_UID=ATU 71176737
